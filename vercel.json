{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "api/admin/*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "api/admin/api/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/admin/?", "dest": "/admin/index.html" },
    { "src": "/admin/(.*)\\.html", "dest": "/admin/$1.html" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)\\.php", "dest": "/api/$1.php" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
